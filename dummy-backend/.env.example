# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Default model to use for requests without a specified model
OPENROUTER_MODEL=openai/gpt-4o-mini

# Demo backend routes:
#   /attack/tool-calling
#   /attack/secret-key
#   /attack/banana

# Tool-calling demo defaults if not provided in request.challenge
TARGET_TOOL_NAME=
TARGET_TOOL_ARGS_JSON={}

# Optional OpenRouter tool spec array (JSON)
# Example: [{"type":"function","function":{"name":"transfer_funds","description":"...","parameters":{"type":"object","properties":{"amount":{"type":"number"}},"required":["amount"]}}}]
CHALLENGE_TOOLS_JSON=[]

# Maximum uploaded file size in megabytes for prompt attachments
MAX_UPLOAD_MB=10

# Optional secret-key fallback for standalone local testing
SECRET_PHRASE=

PORT=8001