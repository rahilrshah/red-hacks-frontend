# Interp backend environment configuration
# Copy to .env and fill in values before running the service.

# Model used by the steering backend
STEER_MODEL_NAME=gpt2

# FastAPI bind port
PORT=8000

# Supabase project URL (used to load steering vectors from PostgREST)
SUPABASE_URL=http://127.0.0.1:54321

# Service-role key for server-side access to steering_vectors
# Either key works; SUPABASE_SERVICE_ROLE_KEY is preferred.
SUPABASE_SERVICE_ROLE_KEY=<from Supabase dashboard or local stack>
PRIVATE_SUPABASE_SERVICE_ROLE_KEY=

# Optional: force CPU if needed by overriding torch device behavior via environment in your launch script
# CUDA_VISIBLE_DEVICES=
