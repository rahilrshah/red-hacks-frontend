# Interp backend environment configuration
# Copy to .env and fill in values before running the service.

# Model used by the steering backend
STEER_MODEL_NAME=gpt2

# FastAPI bind port
PORT=8000

# Supabase project URL (used to load steering vectors from PostgREST)
SUPABASE_URL=http://127.0.0.1:54321

# Service-role key for server-side access to steering_vectors
# Either key works; SUPABASE_SERVICE_ROLE_KEY is preferred.
SUPABASE_SERVICE_ROLE_KEY=<from Supabase dashboard or local stack>
PRIVATE_SUPABASE_SERVICE_ROLE_KEY=

# Shared secret between the SvelteKit server and this backend. The SvelteKit
# route at src/routes/api/steering-vectors/+server.ts attaches this to the
# X-Internal-Secret header on every POST to /v1/steering-vectors. Browsers
# NEVER see this value. Generate a long random string; anything under 32 chars
# is rejected by the Svelte server at startup.
INTERP_INTERNAL_SECRET=

# Toggle user-authored steering vectors. Leave as "true" in production;
# flip to "false" to put the feature into read-only mode without redeploying.
ENABLE_USER_STEERING_VECTORS=true

# Optional: force CPU if needed by overriding torch device behavior via environment in your launch script
# CUDA_VISIBLE_DEVICES=
